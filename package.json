{
  "name": "aas-fleet-agent",
  "version": "1.0.0",
  "description": "Autonomous Arbitrage-as-a-Service Agent for Unicity Testnet v2",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "unicity",
    "sphere-sdk",
    "autonomous-agent",
    "arbitrage",
    "nostr",
    "astridos"
  ],
  "author": "BomBaPhat",
  "license": "MIT",
  "dependencies": {
    "sphere-sdk": "^1.0.0",
    "nostr-tools": "^1.14.0",
    "dotenv": "^16.3.1",
    "pino": "^8.16.2",
    "ethers": "^6.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.1.0",
    "typescript": "^5.2.2"
  }
}