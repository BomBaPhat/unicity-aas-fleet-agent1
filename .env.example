# Unicity Testnet v2 Configuration
UNICITY_RPC_URL=https://testnet2.unicity.network/rpc
UNICITY_CHAIN_ID=9999
UNICITY_NETWORK=testnet2

# Agent Identity & Wallet
AGENT_NAMETAG=AAS-FleetAgent-001
AGENT_MNEMONIC=your_mnemonic_phrase_here_backup_securely
AGENT_WALLET_PASSWORD=secure_password_here

# Market Configuration
MIN_PROFIT_MARGIN_PERCENT=2.5
MAX_POSITION_SIZE_TOKENS=10000
STOP_LOSS_THRESHOLD=500
ESCROW_TIMEOUT_SECONDS=300

# Nostr Configuration (P2P Discovery)
NOSTR_RELAY_URLS=["wss://relay.unicity.network","wss://relay2.unicity.network"]
NOSTR_FILTER_KINDS=[1,23194]
NOSTR_SUBSCRIPTION_ID=aas-fleet-agent-sub-001

# Risk Management
ENABLE_AUTO_LIQUIDATION=true
ENABLE_TIMEOUT_RECOVERY=true
MAX_CONCURRENT_POSITIONS=5
GAS_BUFFER_PERCENT=15

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/agent.log

# AstridOS Environment
ASTRIDOS_SANDBOX_MODE=true
ASTRIDOS_MEMORY_LIMIT_MB=512
ASTRIDOS_CPU_SHARES=1024
PROCESS_ISOLATION_ENABLED=true